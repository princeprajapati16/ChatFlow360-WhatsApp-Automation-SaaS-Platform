SECRET_KEY=django-insecure-dev-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=sqlite:///db.sqlite3
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=10080
API_KEY_PREFIX=cf360
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.yourhost.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@chatflow360.com
EMAIL_HOST_PASSWORD=your-email-password
STATIC_ROOT=staticfiles
MEDIA_ROOT=media

# ── WhatsApp Cloud API ───────────────────────────────────────────────
# Set this to any secret string you'll also paste in Meta Console → Webhook → Verify Token
WHATSAPP_VERIFY_TOKEN=chatflow360_webhook_verify_secret

# Your Meta App Secret from developers.facebook.com → Your App → App Settings → Basic
# Needed to validate X-Hub-Signature-256 on inbound webhooks (leave blank to skip in dev)
WHATSAPP_APP_SECRET=

# Public URL of this Django server (used to display the webhook URL in Settings)
# In production set this to your actual domain e.g. https://api.chatflow360.com
BACKEND_URL=http://localhost:8000

# ── Razorpay ────────────────────────────────────────────────────────
# Get these from https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ── UPI Payment ─────────────────────────────────────────────────────
UPI_ID=yourname@upi
UPI_NAME=ChatFlow360
