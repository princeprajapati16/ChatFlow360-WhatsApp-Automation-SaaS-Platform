# ─────────────────────────────────────────────────────────────
#  ChatFlow360 – Environment Variables
#  Copy this to .env and fill in your real values
# ─────────────────────────────────────────────────────────────

# Django Core
SECRET_KEY=your-very-secret-key-change-me-in-production-min-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DATABASE_URL=postgres://chatflow_user:chatflow_pass@localhost:5432/chatflow360

# Redis
REDIS_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# CORS – comma-separated
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT Token Lifetimes (minutes)
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=10080

# ─────────────────────────────────────────────────────────────
#  WhatsApp Cloud API
# ─────────────────────────────────────────────────────────────
# Get from Meta Business Suite → WhatsApp → API Settings
WHATSAPP_VERIFY_TOKEN=chatflow360_my_verify_token
WHATSAPP_APP_SECRET=your_meta_app_secret_here
WHATSAPP_API_VERSION=v19.0

# ─────────────────────────────────────────────────────────────
#  Stripe Payment Gateway
# ─────────────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─────────────────────────────────────────────────────────────
#  Razorpay (alternative to Stripe)
# ─────────────────────────────────────────────────────────────
# RAZORPAY_KEY_ID=rzp_test_...
# RAZORPAY_KEY_SECRET=...

# ─────────────────────────────────────────────────────────────
#  Email
# ─────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@chatflow360.com

# ─────────────────────────────────────────────────────────────
#  Static / Media
# ─────────────────────────────────────────────────────────────
STATIC_ROOT=staticfiles
MEDIA_ROOT=media

# API Key prefix
API_KEY_PREFIX=cf360
